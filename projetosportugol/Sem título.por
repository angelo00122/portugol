programa {
  funcao inicio() {
    inteiro menor, idade  
    escreva("informe sua idade: ")
    leia(idade)

    se(idade <18) {
      escreva("voce e menor de idade, fala ai menor!!! ")
    }senao{
      escreva("voce e menor de idade ")
      }

      escreva("n/") // comando para quebrar a linha
    }
}
